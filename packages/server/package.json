{
  "name": "server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "build": "tsup src/index.ts --format esm --clean",
    "start": "bun --env-file=../../.env src/index.ts",
    "ai-integration:test": "tsx ai-integration.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env src/database/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.3",
    "@google/generative-ai": "^0.24.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "drizzle-orm": "^0.45.1",
    "groq-sdk": "^0.37.0",
    "hono": "^4.12.5",
    "pino": "^10.3.1",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.9",
    "tsup": "^8.5.1",
    "tsx": "^4.16.2",
    "typescript": "^5.0.0"
  }
}
