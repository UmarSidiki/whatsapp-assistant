# WhatsApp Bot Configuration

# Groq API Keys (supports multiple for load balancing)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_groq_api_key_2_here

# Google Gemini API Keys (supports multiple for load balancing)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_gemini_api_key_2_here

# Production URLs (Required for production deployment)
# For local development, these default to http://localhost:3000
VITE_API_URL=https://assistant.itupdown.com
BETTER_AUTH_URL=https://assistant.itupdown.com

# Logging
LOG_ENABLED=false
