# ─── Server ────────────────────────────────────────────────────────────────────

# Port for the Hono server (default: 3000)
PORT=3000

# Better-Auth secret (required – generate a random string)
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# Better-Auth base URL (required – must match the server's public URL)
BETTER_AUTH_URL=http://localhost:3000

# Allowed frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Logging
LOG_ENABLED=true

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────

# API base URL used by the frontend (no trailing slash)
VITE_API_URL=http://localhost:3000
