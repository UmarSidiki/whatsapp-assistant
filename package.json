{
  "name": "whatsapp-bot",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w packages/web\" \"npm run dev -w packages/server\"",
    "build": "npm run build -w packages/web && npm run build -w packages/server",
    "start": "npm run start -w packages/server",
    "db:generate": "npm run db:generate -w packages/server",
    "db:migrate": "npm run db:migrate -w packages/server",
    "db:studio": "npm run db:studio -w packages/server",
    "deploy": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "version": "1.0.0"
}
