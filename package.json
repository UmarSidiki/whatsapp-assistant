{
  "name": "whatsapp-bot",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run --cwd packages/web dev\" \"bun --env-file=.env run --cwd packages/server dev\"",
    "build": "bun run --cwd packages/web build && bun run --cwd packages/server build",
    "start": "bun --env-file=.env run --cwd packages/server start",
    "db:generate": "bun --env-file=.env run --cwd packages/server db:generate",
    "db:migrate": "bun --env-file=.env run --cwd packages/server db:migrate",
    "db:push": "bun --env-file=.env run --cwd packages/server db:push",
    "db:studio": "bun --env-file=.env run --cwd packages/server db:studio",
    "deploy": "bash scripts/deploy.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "version": "1.0.0"
}
